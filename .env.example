# Spotify API Credentials (from https://developer.spotify.com/dashboard)
CLIENTID=your_spotify_client_id
CLIENTSECRET=your_spotify_client_secret

# Backend base URL - set to your public URL + /api
# Example: http://YOUR_SERVER_IP:80/api
BASE_URL=http://localhost:3000

# Frontend URL - set to your public URL
# Example: http://YOUR_SERVER_IP:80
FRONTEND_URL=http://localhost:5173
